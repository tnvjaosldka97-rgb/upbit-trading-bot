# ─── 업비트 API 키 ───────────────────────────────────
# 업비트 → 마이페이지 → Open API 관리에서 발급
# 권한: 자산조회 + 주문하기 체크 (출금 권한은 체크하지 말 것)
# IP 허용 등록 필수 (봇 부팅 시 preflight가 현재 공인 IP 표시)
UPBIT_ACCESS_KEY=여기에_발급받은_액세스키_입력
UPBIT_SECRET_KEY=여기에_발급받은_시크릿키_입력

# ─── 운용 설정 ───────────────────────────────────────
INITIAL_CAPITAL=100000      # 시작 자본 (원)
BOT_MODE=CALIBRATION        # CALIBRATION | LIVE
DRY_RUN=true                # true=시뮬레이션만 | false=실거래
PORT=4020                   # 대시보드 포트 (충돌 시 자동으로 4021~)

# ─── Telegram 알림 (선택) ────────────────────────────
# @BotFather에서 봇 만들고 토큰 발급, 봇에게 /start 한 번 보내면 chat_id 자동 감지
# 비워두면 알림 자동 비활성화
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ─── 글로벌 거래소 API 키 (아비트라지 — 선택) ────────
BITHUMB_API_KEY=
BITHUMB_SECRET_KEY=
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BYBIT_API_KEY=
BYBIT_SECRET_KEY=
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
GATE_API_KEY=
GATE_SECRET_KEY=

# ─── 크로스 아비트라지 설정 ──────────────────────────
ARB_ENABLED=true            # 아비트라지 모니터링 on/off
ARB_MAX_POSITION_USD=500
ARB_MIN_SPREAD_PCT=1.2
ARB_REBALANCE_THRESHOLD=0.3
