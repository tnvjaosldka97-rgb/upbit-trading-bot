# ─── 업비트 API 키 ───────────────────────────────────
# 업비트 → 마이페이지 → Open API 관리에서 발급
# 권한: 자산조회 + 주문하기 체크
# IP 허용 등록 필수
UPBIT_ACCESS_KEY=여기에_발급받은_액세스키_입력
UPBIT_SECRET_KEY=여기에_발급받은_시크릿키_입력

# ─── 운용 설정 ───────────────────────────────────────
INITIAL_CAPITAL=100000      # 시작 자본 (원)
BOT_MODE=CALIBRATION        # CALIBRATION | LIVE
DRY_RUN=true                # true=시뮬레이션만 | false=실거래
