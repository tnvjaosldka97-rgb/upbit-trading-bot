# Copy this to .env and fill in your values

# Polymarket wallet credentials
PRIVATE_KEY=0x...
WALLET_ADDRESS=0x...
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Polygon RPC — get a free key from https://alchemy.com or https://quicknode.com
# Public RPC works but is slow. Premium RPC required for on-chain copy trading.
POLYGON_RPC=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY_HERE

# Capital ($100 시드)
BANKROLL=100

# Safety: start in dry-run mode, set to false only after testing
DRY_RUN=true

# Kelly fraction override (optional — default is phase-in schedule from config.py)
# KELLY_FRACTION=0.05

# Database path
DB_PATH=prediction_edge.db
